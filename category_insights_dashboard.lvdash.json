{
  "version": "v2",
  "name": "Healthcare Supply Chain - Category Insights Dashboard",
  "datasets": [
    {
      "name": "category_insights",
      "displayName": "Category Insights Data",
      "query": "SELECT * FROM archana_krish_fe_dsa.vizient_deep_dive.category_insights_delta"
    }
  ],
  "pages": [
    {
      "name": "overview",
      "displayName": "Executive Overview",
      "layout": [
        {
          "widget": {
            "name": "total_spend_kpi",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "category_insights",
                  "fields": [
                    {
                      "name": "TotalSpend",
                      "expression": "SUM(`AnnualSpend`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "TotalSpend",
                  "format": {
                    "type": "currency",
                    "currency": "USD",
                    "abbreviation": "compact",
                    "decimalPlaces": {
                      "type": "exact",
                      "places": 0
                    }
                  },
                  "displayName": "Total Annual Spend"
                }
              },
              "frame": {
                "showTitle": true,
                "title": "💰 Total Annual Spend"
              }
            }
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 2,
            "height": 2
          }
        },
        {
          "widget": {
            "name": "savings_opportunity_kpi",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "category_insights",
                  "fields": [
                    {
                      "name": "TotalSavings",
                      "expression": "SUM(`SavingsOpportunity`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "TotalSavings",
                  "format": {
                    "type": "currency",
                    "currency": "USD",
                    "abbreviation": "compact",
                    "decimalPlaces": {
                      "type": "exact",
                      "places": 0
                    }
                  },
                  "displayName": "Total Savings Opportunity"
                }
              },
              "frame": {
                "showTitle": true,
                "title": "🎯 Potential Savings"
              }
            }
          },
          "position": {
            "x": 2,
            "y": 0,
            "width": 2,
            "height": 2
          }
        },
        {
          "widget": {
            "name": "price_index_kpi",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "category_insights",
                  "fields": [
                    {
                      "name": "AvgPriceIndex",
                      "expression": "AVG(`PriceIndex`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "AvgPriceIndex",
                  "format": {
                    "type": "percentage",
                    "decimalPlaces": {
                      "type": "exact",
                      "places": 1
                    }
                  },
                  "displayName": "Average Price Index"
                }
              },
              "frame": {
                "showTitle": true,
                "title": "📊 Avg Price Index"
              }
            }
          },
          "position": {
            "x": 4,
            "y": 0,
            "width": 2,
            "height": 2
          }
        },
        {
          "widget": {
            "name": "spend_distribution_pie",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "category_insights",
                  "fields": [
                    {
                      "name": "Category",
                      "expression": "`Category`"
                    },
                    {
                      "name": "CategorySpend",
                      "expression": "SUM(`AnnualSpend`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "pie",
              "encodings": {
                "angle": {
                  "fieldName": "CategorySpend",
                  "scale": {
                    "type": "quantitative"
                  },
                  "displayName": "Category Spend"
                },
                "color": {
                  "fieldName": "Category",
                  "scale": {
                    "type": "categorical"
                  },
                  "displayName": "Category"
                },
                "label": {
                  "show": true
                }
              },
              "frame": {
                "showTitle": true,
                "title": "💵 Spend Distribution by Category"
              }
            }
          },
          "position": {
            "x": 0,
            "y": 2,
            "width": 3,
            "height": 4
          }
        },
        {
          "widget": {
            "name": "savings_by_category_bar",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "category_insights",
                  "fields": [
                    {
                      "name": "Category",
                      "expression": "`Category`"
                    },
                    {
                      "name": "CategorySavings",
                      "expression": "SUM(`SavingsOpportunity`)"
                    }
                  ],
                  "disaggregated": false,
                  "orderBy": [
                    {
                      "name": "CategorySavings",
                      "direction": "DESC"
                    }
                  ]
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "CategorySavings",
                  "scale": {
                    "type": "quantitative"
                  },
                  "axis": {
                    "hideTitle": false
                  },
                  "displayName": "Savings Opportunity ($)"
                },
                "y": {
                  "fieldName": "Category",
                  "scale": {
                    "type": "categorical",
                    "sort": {
                      "by": "x-reversed"
                    }
                  },
                  "axis": {
                    "hideLabels": false,
                    "hideTitle": true
                  },
                  "displayName": "Category"
                },
                "color": {
                  "fieldName": "Category",
                  "scale": {
                    "type": "categorical"
                  },
                  "displayName": "Category"
                }
              },
              "frame": {
                "showTitle": true,
                "title": "🎯 Savings Opportunity by Category"
              }
            }
          },
          "position": {
            "x": 3,
            "y": 2,
            "width": 3,
            "height": 4
          }
        },
        {
          "widget": {
            "name": "price_index_variance_bar",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "category_insights",
                  "fields": [
                    {
                      "name": "Category",
                      "expression": "`Category`"
                    },
                    {
                      "name": "AvgPriceIndex",
                      "expression": "AVG(`PriceIndex`)"
                    },
                    {
                      "name": "MinPriceIndex",
                      "expression": "MIN(`PriceIndex`)"
                    },
                    {
                      "name": "MaxPriceIndex",
                      "expression": "MAX(`PriceIndex`)"
                    }
                  ],
                  "disaggregated": false,
                  "orderBy": [
                    {
                      "name": "AvgPriceIndex",
                      "direction": "DESC"
                    }
                  ]
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "AvgPriceIndex",
                  "scale": {
                    "type": "quantitative"
                  },
                  "axis": {
                    "hideTitle": false
                  },
                  "displayName": "Average Price Index"
                },
                "y": {
                  "fieldName": "Category",
                  "scale": {
                    "type": "categorical",
                    "sort": {
                      "by": "x-reversed"
                    }
                  },
                  "axis": {
                    "hideLabels": false,
                    "hideTitle": true
                  },
                  "displayName": "Category"
                },
                "color": {
                  "fieldName": "Category",
                  "scale": {
                    "type": "categorical"
                  },
                  "displayName": "Category"
                }
              },
              "frame": {
                "showTitle": true,
                "title": "📈 Price Index Variance by Category"
              }
            }
          },
          "position": {
            "x": 0,
            "y": 6,
            "width": 6,
            "height": 4
          }
        },
        {
          "widget": {
            "name": "top_savings_items",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "category_insights",
                  "fields": [
                    {
                      "name": "ItemName",
                      "expression": "`ItemName`"
                    },
                    {
                      "name": "Category",
                      "expression": "`Category`"
                    },
                    {
                      "name": "SavingsOpportunity",
                      "expression": "`SavingsOpportunity`"
                    },
                    {
                      "name": "PriceIndex",
                      "expression": "`PriceIndex`"
                    }
                  ],
                  "disaggregated": true,
                  "orderBy": [
                    {
                      "name": "SavingsOpportunity",
                      "direction": "DESC"
                    }
                  ],
                  "limit": 10
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "SavingsOpportunity",
                  "scale": {
                    "type": "quantitative"
                  },
                  "axis": {
                    "hideTitle": false
                  },
                  "displayName": "Savings Opportunity ($)"
                },
                "y": {
                  "fieldName": "ItemName",
                  "scale": {
                    "type": "categorical",
                    "sort": {
                      "by": "x-reversed"
                    }
                  },
                  "axis": {
                    "hideLabels": true,
                    "hideTitle": true
                  },
                  "displayName": "Item Name"
                },
                "color": {
                  "fieldName": "Category",
                  "scale": {
                    "type": "categorical"
                  },
                  "displayName": "Category"
                }
              },
              "frame": {
                "showTitle": true,
                "title": "🏆 Top 10 Items by Savings Opportunity"
              }
