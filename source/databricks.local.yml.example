# Copy to databricks.local.yml (gitignored) for local testing without editing committed YAML.
#
#   cp databricks.local.yml.example databricks.local.yml
#
# Replace placeholders with your source workspace host, CLI profile, catalog, and export volume path.

targets:
  default:
    workspace:
      host: https://YOUR-SOURCE-WORKSPACE.cloud.databricks.com
      profile: YOUR_SOURCE_PROFILE
    variables:
      source_workspace_url: https://YOUR-SOURCE-WORKSPACE.cloud.databricks.com
      catalog: YOUR_SOURCE_CATALOG
      volume_base: /Volumes/YOUR_SOURCE_CATALOG/YOUR_SCHEMA/YOUR_EXPORT_VOLUME
