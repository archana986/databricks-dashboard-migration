{
  "source": {
    "workspace": "https://dev-workspace.cloud.databricks.com",
    "dashboard_id": "${SOURCE_DASHBOARD_ID}",
    "pat_token": "${SOURCE_PAT_TOKEN}"
  },
  "target": {
    "workspace": "https://dev-target-workspace.cloud.databricks.com",
    "dashboard_name": "Dashboard - Dev Environment",
    "path": "/Workspace/Users/${USER_EMAIL}/Dashboards/Dev",
    "warehouse_id": "${TARGET_WAREHOUSE_ID}",
    "pat_token": "${TARGET_PAT_TOKEN}"
  },
  "auth_method": "pat",
  "validate_queries": true,
  "publish": false,
  "create_backup": true,
  "catalog_schema_map": {
    "prod_catalog.prod_schema": "dev_catalog.dev_schema"
  }
}
