{
  "source": {
    "workspace": "https://staging-workspace.cloud.databricks.com",
    "dashboard_id": "${SOURCE_DASHBOARD_ID}",
    "pat_token": "${SOURCE_PAT_TOKEN}"
  },
  "target": {
    "workspace": "https://prod-workspace.cloud.databricks.com",
    "dashboard_name": "Dashboard - Production",
    "path": "/Workspace/Users/${USER_EMAIL}/Dashboards/Production",
    "warehouse_id": "${TARGET_WAREHOUSE_ID}",
    "pat_token": "${TARGET_PAT_TOKEN}"
  },
  "auth_method": "pat",
  "validate_queries": true,
  "publish": true,
  "embed_credentials": false,
  "create_backup": true,
  "catalog_schema_map": {
    "staging_catalog.staging_schema": "prod_catalog.prod_schema"
  }
}
