# ============================================================================
# Databricks Dashboard Migration Toolkit - .gitignore
# ============================================================================
# Exemplar structure:
#   source/ (source bundle: databricks.yml, resources/, notebooks/, helpers/)
#   target/ (target bundle: databricks.yml, resources/, notebooks/, helpers/)
#   SETUP.md, README.md, WHY_THIS_TOOLKIT.md, catalog_schema_mapping_template.csv
# ============================================================================

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/

# ----- Databricks bundle state -----
.databricks/
ip-detection/.databricks/

# ----- Legacy shared src/ (now split into source/ and target/) -----
src/

# ----- Archive (old docs, scripts, notebooks - not part of exemplar) -----
archive/
_archive/
_local_archive/

# ----- Temp / test / output files -----
temp/
_temp/
bundle_deploy_*/
dashboard_bundle/
transformed/
exported/

# ----- Dashboard / data files (generated at runtime) -----
*.lvdash.json
*_dashboard.json
*.csv
!catalog_schema_mapping_template.csv

# ----- User-specific local config -----
catalog_schema_mapping.csv
config/config.yaml
dev_config.py
source/databricks.local.yml
target/databricks.local.yml

# ----- macOS -----
.DS_Store

# ----- IDE / editor -----
.vscode/
.idea/
.cursor/
*.swp
*.swo

# ----- Internal / verification docs (not customer-facing) -----
VERIFICATION_DASHBOARD_MIGRATION.md
PROBLEM_AND_OPPORTUNITY_STATEMENT.md
transcripts/

# ----- Local personal notes (move to archive/ if keeping) -----
cursor_*.md
LOCAL_RUN_LOG.md
EXECUTION_STEPS_*.md
EXEMPLAR_REORG_PLAN.md
execution_steps_*.md
GIT_PUSH_GUIDE.md
GIT_WORKFLOW.md
CONFIG_SKIP_WORKTREE_GUIDE.md
CONFIG_SETUP_COMPLETE.md
localplandoc.md
