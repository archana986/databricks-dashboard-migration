# Copy to databricks.local.yml (gitignored).
targets:
  default:
    workspace:
      profile: your-cli-profile
      host: https://YOUR-SOURCE-WORKSPACE.cloud.databricks.com
      root_path: /Workspace/Users/${workspace.current_user.userName}/.bundle/${bundle.name}
    variables:
      catalog: your_source_catalog
      target_catalog: your_target_catalog
      schema: your_schema
      volume: your_volume
      target_host: https://YOUR-TARGET-WORKSPACE.cloud.databricks.com
